graph TD
    subgraph Camada_Neuroscience [🧠 Neurociência & Psicologia]
        G1[Gatilhos Mentais: Escassez, Urgência, Reciprocidade...]
        G2[Heurísticas: Ancoragem, Aversão à Perda]
        G3[Arquétipos de Marca]
    end

    subgraph Camada_Automacao [🤖 Automação & IA]
        A1[Lead Scoring]
        A2[Lead Nurturing]
        A3[Personalização Preditiva]
        A4[Chatbots / CDP]
    end

    subgraph Camada_Atribuicao [📊 Atribuição & Métricas]
        M1[Modelos: First-touch, Last-touch, Linear, U-shaped, Data-driven]
        M2[Métricas: CAC, LTV, ROI, ROAS, Taxa Conversão, Vazamento]
    end

    subgraph Camada_Conteudo [🎯 Conteúdo por Estágio]
        C1[ToFu: Educação, Blog, E-books]
        C2[MoFu: Cases, Webinars, Comparativos]
        C3[BoFu: Demo, Proposta, Urgência]
    end

    subgraph Camada_AARRR [🔁 Pirate Metrics - AARRR]
        P1[Aquisição → Ativação → Retenção → Receita → Referência]
    end

    subgraph Camada_Jornada [🧩 Jornada Não Linear + Touchpoints]
        J1[Awareness → Consideration → Decision → Loyalty → Advocacy]
        J2[Canais: Mídia Paga, Orgânico, E-mail, Social, Indicação]
    end

    subgraph Camada_Classica [🏛️ Clássico AIDA / ToFu-MoFu-BoFu]
        K1[Atenção → Interesse → Desejo → Ação]
        K2[ToFu (Topo) | MoFu (Meio) | BoFu (Fundo)]
    end

    Camada_Classica --> Camada_Jornada
    Camada_Jornada --> Camada_AARRR
    Camada_AARRR --> Camada_Conteudo
    Camada_Conteudo --> Camada_Atribuicao
    Camada_Atribuicao --> Camada_Automacao
    Camada_Automacao --> Camada_Neuroscience

