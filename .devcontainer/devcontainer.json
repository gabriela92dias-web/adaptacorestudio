{
  "name": "Adapta Core Studio",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "postCreateCommand": "npm install --legacy-peer-deps",
  "postStartCommand": "fuser -k 3333/tcp 3001/tcp 2>/dev/null; nohup npm run start > /tmp/hono.log 2>&1 & sleep 2; nohup npm run dev > /tmp/vite.log 2>&1 &",
  "forwardPorts": [3001, 3333],
  "portsAttributes": {
    "3001": {
      "label": "Frontend (Vite)",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "3333": {
      "label": "Backend API (Hono)",
      "onAutoForward": "ignore",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  }
}
