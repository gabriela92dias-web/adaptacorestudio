# ============================================================
# ADAPTA CoreStudio — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env com valores reais.

# --- Supabase (Frontend + Backend REST) ---
# URL do projeto Supabase (ex: https://xxxx.supabase.co)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública anon do Supabase (segura para expor no frontend)
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# --- Banco de Dados (Backend Kysely — connection string PostgreSQL) ---
# Use UMA das opções abaixo. O sistema tenta nessa ordem:
# 1. DATABASE_URL (padrão Render / Railway)
# 2. SUPABASE_DB_URL (Supabase Transaction Pooler)
# 3. FLOOT_DATABASE_URL (legado)
#
# Para obter a connection string do Supabase:
# Acesse: https://supabase.com/dashboard/project/SEU-PROJETO/settings/database
# Use a opção "Transaction Pooler" (porta 6543) para ambientes serverless.
DATABASE_URL=postgresql://postgres.SEU-PROJETO:SUA-SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# --- Integrações Opcionais ---
OPENAI_API_KEY=sua-openai-key-opcional
