2. CSS Raiz com Estados
Copy/* adapta-root.css */
/* CONFIDENCIAL • © 2026 Adapta */

:root {
  /* ========== CORES CORE ADAPTA ========== */
  
  /* LUZ - Brancura e Claridade */
  --luz-sage-mist: #FAFBFA;
  --luz-hemp-canvas: #F7F9F8;
  --luz-sage-whisper: #EDF1EF;

  /* ALMA - Meio-termo */
  --alma-green-smoke: #8FA89B;
  --alma-emerald-haze: #6A8A7A;
  --alma-deep-pine: #455A4F;

  /* FIRMEZA - Densidade Escura */
  --firmeza-dark-forest: #1A231D;
  --firmeza-black-earth: #141A17;
  --firmeza-deep-shadow: #0F1411;

  /* CANDY - Verde Limão Pastel */
  --candy-marshmallow: #F7FBF0;
  --candy-acucar: #EFF7E0;
  --candy-baunilha: #E5F2D0;

  /* LEMON - Verde Limão Suave */
  --lemon-neblina: #F5F9F2;
  --lemon-vapor: #EAF3E5;
  --lemon-citrus: #DFEDD8;

  /* VENTURA - Verde Acinzentado */
  --ventura-nevoa-clara: #E8EFE0;
  --ventura-fumaca: #D7E3CC;
  --ventura-bruma: #C1D4B2;

  /* ENERGIA - Luz Quente */
  --energia-campo-alto: #FFFAE0;
  --energia-campo-velado: #FFE7A3;
  --energia-centro: #FFE2C2;

  /* ALEGRIA - Rosa Vivo */
  --alegria-campo-alto: #FDE2DD;
  --alegria-campo-velado: #FFC8C2;
  --alegria-centro: #FFA3B1;

  /* SEGURANÇA - Lavanda Rosada */
  --seguranca-campo-alto: #F1E6F0;
  --seguranca-campo-velado: #DEC7DE;
  --seguranca-centro: #D0AEE0;

  /* ========== CORES DE ESTADO - OBRIGATÓRIAS ========== */
  /* Estabelecidas: 2026-03-11T04:00:00Z */
  
  /* STATUS: ERRO */
  --status-error-primary: #E84545;
  --status-error-light: #FDE2DD;
  --status-error-dark: #8B2C2C;
  --status-error-border: #D94C4C;
  
  /* STATUS: SUCESSO */
  --status-success-primary: #2D7A4F;
  --status-success-light: #E8F5E9;
  --status-success-dark: #1B4D31;
  --status-success-border: #4A9D6F;
  
  /* STATUS: AVISO */
  --status-warning-primary: #D97706;
  --status-warning-light: #FEF3C7;
  --status-warning-dark: #92400E;
  --status-warning-border: #F59E0B;
  
  /* STATUS: INFORMAÇÃO */
  --status-info-primary: #0EA5E9;
  --status-info-light: #E0F2FE;
  --status-info-dark: #0369A1;
  --status-info-border: #06B6D4;

  /* ========== TEMAS ========== */
  
  /* TEMA CLARO */
  --theme-light-bg-primary: var(--luz-hemp-canvas);
  --theme-light-bg-secondary: var(--luz-sage-whisper);
  --theme-light-bg-tertiary: var(--luz-sage-mist);
  --theme-light-text-primary: var(--alma-deep-pine);
  --theme-light-text-secondary: var(--alma-green-smoke);
  --theme-light-border: var(--alma-emerald-haze);

  /* TEMA ESCURO */
  --theme-dark-bg-primary: var(--firmeza-black-earth);
  --theme-dark-bg-secondary: var(--firmeza-dark-forest);
  --theme-dark-bg-tertiary: var(--firmeza-dark-forest);
  --theme-dark-text-primary: var(--luz-hemp-canvas);
  --theme-dark-text-secondary: var(--luz-sage-whisper);
  --theme-dark-border: var(--alma-emerald-haze);
}

/* TEMA CLARO */
[data-theme="light"],
[data-theme=""],
html:not([data-theme]) {
  color-scheme: light;
  
  --bg-primary: var(--theme-light-bg-primary);
  --bg-secondary: var(--theme-light-bg-secondary);
  --bg-tertiary: var(--theme-light-bg-tertiary);
  --text-primary: var(--theme-light-text-primary);
  --text-secondary: var(--theme-light-text-secondary);
  --border-color: var(--theme-light-border);
}

/* TEMA ESCURO */
[data-theme="dark"] {
  color-scheme: dark;
  
  --bg-primary: var(--theme-dark-bg-primary);
  --bg-secondary: var(--theme-dark-bg-secondary);
  --bg-tertiary: var(--theme-dark-bg-tertiary);
  --text-primary: var(--theme-dark-text-primary);
  --text-secondary: var(--theme-dark-text-secondary);
  --border-color: var(--theme-dark-border);
}

/* Suportar preferência do SO */
@media (prefers-color-scheme: dark) {
  html:not([data-theme]) {
    --bg-primary: var(--theme-dark-bg-primary);
    --bg-secondary: var(--theme-dark-bg-secondary);
    --bg-tertiary: var(--theme-dark-bg-tertiary);
    --text-primary: var(--theme-dark-text-primary);
    --text-secondary: var(--theme-dark-text-secondary);
    --border-color: var(--theme-dark-border);
  }
}

/* ========== COMPONENTES PADRÃO ========== */

body {
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* Mensagens de Estado */
.alert-error,
.alert-danger,
[role="alert"][data-status="error"] {
  background-color: var(--status-error-light);
  color: var(--status-error-dark);
  border: 2px solid var(--status-error-border);
  border-radius: 8px;
  padding: 12px 16px;
}

.alert-error-icon {
  color: var(--status-error-primary);
}

.alert-success,
[role="alert"][data-status="success"] {
  background-color: var(--status-success-light);
  color: var(--status-success-dark);
  border: 2px solid var(--status-success-border);
  border-radius: 8px;
  padding: 12px 16px;
}

.alert-success-icon {
  color: var(--status-success-primary);
}

.alert-warning,
[role="alert"][data-status="warning"] {
  background-color: var(--status-warning-light);
  color: var(--status-warning-dark);
  border: 2px solid var(--status-warning-border);
  border-radius: 8px;
  padding: 12px 16px;
}

.alert-warning-icon {
  color: var(--status-warning-primary);
}

.alert-info,
[role="alert"][data-status="info"] {
  background-color: var(--status-info-light);
  color: var(--status-info-dark);
  border: 2px solid var(--status-info-border);
  border-radius: 8px;
  padding: 12px 16px;
}

.alert-info-icon {
  color: var(--status-info-primary);
}

/* Validação de Formulário */
.form-control {
  border-color: var(--border-color);
  color: var(--text-primary);
  background-color: var(--bg-primary);
}

.form-control:focus {
  border-color: var(--status-info-primary);
  box-shadow: 0 0 0 3px var(--status-info-light);
}

.form-control.is-invalid {
  border-color: var(--status-error-primary);
  background-color: var(--status-error-light);
}

.form-control.is-invalid:focus {
  border-color: var(--status-error-primary);
  box-shadow: 0 0 0 3px rgba(232, 69, 69, 0.1);
}

.form-control.is-valid {
  border-color: var(--status-success-primary);
  background-color: var(--status-success-light);
}

.form-control.is-valid:focus {
  border-color: var(--status-success-primary);
  box-shadow: 0 0 0 3px rgba(45, 122, 79, 0.1);
}

/* Feedback de Validação */
.invalid-feedback {
  color: var(--status-error-primary);
  font-size: 0.875rem;
  margin-top: 4px;
}

.valid-feedback {
  color: var(--status-success-primary);
  font-size: 0.875rem;
  margin-top: 4px;
}

/* Botões */
.btn {
  border-radius: 8px;
  font-weight: 500;
  transition: all 0.2s ease-in-out;
}

.btn-primary {
  background-color: var(--alma-deep-pine);
  border-color: var(--alma-deep-pine);
  color: var(--luz-hemp-canvas);
}

.btn-primary:hover {
  background-color: var(--alma-emerald-haze);
  border-color: var(--alma-emerald-haze);
}

.btn-primary:focus {
  box-shadow: 0 0 0 3px rgba(69, 90, 79, 0.2);
}

.btn-danger {
  background-color: var(--status-error-primary);
  border-color: var(--status-error-primary);
  color: white;
}

.btn-danger:hover {
  background-color: var(--status-error-dark);
  border-color: var(--status-error-dark);
}

.btn-success {
  background-color: var(--status-success-primary);
  border-color: var(--status-success-primary);
  color: white;
}

.btn-success:hover {
  background-color: var(--status-success-dark);
  border-color: var(--status-success-dark);
}

.btn-warning {
  background-color: var(--status-warning-primary);
  border-color: var(--status-warning-primary);
  color: white;
}

.btn-warning:hover {
  background-color: var(--status-warning-dark);
  border-color: var(--status-warning-dark);
}

.btn-info {
  background-color: var(--status-info-primary);
  border-color: var(--status-info-primary);
  color: white;
}

.btn-info:hover {
  background-color: var(--status-info-dark);
  border-color: var(--status-info-dark);
}

/* Badges */
.badge-error {
  background-color: var(--status-error-primary);
  color: white;
}

.badge-success {
  background-color: var(--status-success-primary);
  color: white;
}

.badge-warning {
  background-color: var(--status-warning-primary);
  color: white;
}

.badge-info {
  background-color: var(--status-info-primary);
  color: white;
}

/* Notificações */
.notification {
  border-radius: 8px;
  padding: 16px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.notification.error {
  background-color: var(--status-error-light);
  border-left: 4px solid var(--status-error-primary);
}

.notification.success {
  background-color: var(--status-success-light);
  border-left: 4px solid var(--status-success-primary);
}

.notification.warning {
  background-color: var(--status-warning-light);
  border-left: 4px solid var(--status-warning-primary);
}

.notification.info {
  background-color: var(--status-info-light);
  border-left: 4px solid var(--status-info-primary);
}

/* Ícones de Estado */
.icon-error {
  color: var(--status-error-primary);
}

.icon-success {
  color: var(--status-success-primary);
}

.icon-warning {
  color: var(--status-warning-primary);
}

.icon-info {
  color: var(--status-info-primary);
}

/* Links */
a {
  color: var(--alma-deep-pine);
  text-decoration: underline;
}

a:hover {
  color: var(--alma-emerald-haze);
}

a:focus {
  outline: 2px solid var(--status-info-primary);
  outline-offset: 2px;
}

/* Código */
code, pre {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
  border-radius: 4px;
}

/* Tabelas */
table {
  border-collapse: collapse;
}

table th {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
  padding: 12px;
}

table td {
  border: 1px solid var(--border-color);
  padding: 12px;
}

table tbody tr:hover {
  background-color: var(--bg-secondary);
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-secondary);
}

::-webkit-scrollbar-thumb {
  background: var(--alma-green-smoke);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--alma-emerald-haze);
}

/* Seleção */
::selection {
  background-color: var(--status-info-primary);
  color: white;
}

/* Placeholder */
::placeholder {
  color: var(--text-secondary);
}