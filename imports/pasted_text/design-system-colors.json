  "operationalRules": {
    "rule1": "VERDE + AMARELO JAMAIS - Exceção: Copa do Mundo. Evitar associação cromática.",
    "rule2": "GRADIENTES SUAVES - Nunca cores complementares. Usar análogas/monocromáticas.",
    "rule3": "COLOR CORE = CONTEÚDO - Restrito a materiais promocionais. Não em UI estrutural.",
    "rule4": "NEUTRALS = ESTRUTURA - Base de toda interface. Backgrounds, cards, borders, texto.",
    "rule5": "VERDE = MONOCROMÁTICO - Verde institucional sempre sozinho. Não mix com Color Core.",
    "rule6": "WCAG 2.1 AA MÍNIMO - Contraste 4.5:1 texto normal, 3:1 texto grande. AAA ideal."
  },
  "summary": "45 cores • 9 espectros • RGB/HSL/HEX • WCAG 2.1 AA/AAA"
